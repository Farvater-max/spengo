{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.webspengo.xyz" }],
      "destination": "https://webspengo.xyz/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/privacy-policy",  "destination": "/privacy-policy.html" },
    { "source": "/privacy-policy/", "destination": "/privacy-policy.html" },
    { "source": "/features",        "destination": "/features.html" },
    { "source": "/features/",       "destination": "/features.html" },
    { "source": "/articles",        "destination": "/articles.html" },
    { "source": "/articles/",       "destination": "/articles.html" },
    { "source": "/blog",            "destination": "/blog.html" },
    { "source": "/blog/",           "destination": "/blog.html" },
    {
      "source": "/blog/spengo-expense-tracker-how-to-add-expenses",
      "destination": "/blog/spengo-expense-tracker-how-to-add-expenses.html"
    },
    {
      "source": "/blog/spengo-expense-tracker-how-to-add-expenses/",
      "destination": "/blog/spengo-expense-tracker-how-to-add-expenses.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    }
  ]
}